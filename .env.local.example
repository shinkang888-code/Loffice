# Loffice Environment Variables

# === Web (Vercel) ===
NEXT_PUBLIC_ENGINE_URL=https://loffice-engine.onrender.com
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# === Engine (Render) ===
LOFFICE_ENGINE_PORT=10000
LIBREOFFICE_PATH=/usr/bin/soffice
WOPI_HOST=https://loffice-engine.onrender.com
COLLABORA_URL=https://your-collabora.onrender.com
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
